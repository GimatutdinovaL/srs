{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/GimatutdinovaL/srs/refs/heads/main/карты.json",
  "title": "OpenAPI-спецификация Сервиса управления банковскими картами",
  "description": "Методы для управления банковскими картами. Все схемы запросов и ответов соответствуют JSON Schema не ниже Draft 4",
  "type": "object",
  "properties": {
    "Link": {
      "type": "object",
      "properties": {
        "href": {
          "type": "string",
          "description": "URL ссылки"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "description": "HTTP метод"
        }
      },
      "required": ["href", "method"],
      "additionalProperties": false
    },
    
    "CardProduct": {
      "type": "object",
      "description": "Вид банковской карты",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор вида карты"
        },
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        }
      },
      "required": ["id", "productType"],
      "additionalProperties": false
    },
    
    "CardProductsRS": {
      "type": "object",
      "description": "Список карт",
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "$ref": "#/properties/CardProduct"
          }
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "create_card": {
              "$ref": "#/properties/Link",
              "description": "Cсылка на создание зявки на новую карту"
            }
          },
          "required": ["self", "create_card"],
          "additionalProperties": false
        }
      },
      "required": ["products", "_links"],
      "additionalProperties": false
    },
    
    "CardRQ": {
      "type": "object",
      "description": "Запрос на создание заявки на новую карту",
      "properties": {
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        }
      },
      "required": ["productType"],
      "additionalProperties": false
    },
    
    "CardRS": {
      "type": "object",
      "description": "Ответ на создание заявки на новую карту",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор заявки на карту"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время создания"
        },
        "cardStatus": {
          "type": "string",
          "enum": ["NEW", "IN_PROGRESS", "COMPLETED", "CANCELLED"],
          "description": "Статус заказа"
        },
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "cancel": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для отмены заявки"
            },
            "delivery_address": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для указания адреса доставки"
            }
          },
          "required": ["self", "cancel", "delivery_address"],
          "additionalProperties": false
        }
      },
      "required": ["id", "date", "cardStatus", "productType", "_links"],
      "additionalProperties": false
    },
    
    "DeliveryAddressCardRQ": {
      "type": "object",
      "description": "Запрос на создание адреса доставки",
      "properties": {
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Комментарий для курьера (опционально)"
        }
      },
      "required": ["cardId", "country", "city", "street", "houseNumber", "apartment"],
      "additionalProperties": false
    },
    
    "DeliveryAddressCardRS": {
      "type": "object",
      "description": "Ответ на создание адреса доставки",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор адреса"
        },
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "minLength": 0,
          "maxLength": 200,
          "description": "Комментарий для курьера"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время создания адреса"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "update": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для обновления адреса доставки"
            }
          },
          "required": ["self", "update"],
          "additionalProperties": false
        }
      },
      "required": ["id", "cardId", "createdAt", "_links"],
      "additionalProperties": false
    },
    
    "DeliveryAddressUpdateRQ": {
      "type": "object",
      "description": "Запрос на обновление адреса доставки",
      "properties": {
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "minLength": 0,
          "maxLength": 200,
          "description": "Комментарий для курьера"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    
    "DeliveryAddressUpdateRS": {
      "type": "object",
      "description": "Ответ на обновление адреса доставки",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор адреса"
        },
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "minLength": 0,
          "maxLength": 200,
          "description": "Комментарий для курьера"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время обновления адреса"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для получения информации об обновленном адресе"
            }
          },
          "required": ["self"],
          "additionalProperties": false
        }
      },
      "required": ["id", "cardId", "updatedAt", "_links"],
      "additionalProperties": false
    },
    
    "TwoFactorAuthRQ": {
      "type": "object",
      "description": "Запрос на двухфакторную аутентификацию",
      "properties": {
        "code": {
          "type": "string",
          "description": "Код подтверждения из SMS"
        },
        "sessionId": {
          "type": "string",
          "format": "uuid",
          "description": "Идентификатор сессии"
        }
      },
      "required": ["code", "sessionId"],
      "additionalProperties": false
    },
    
    "TwoFactorAuthRS": {
      "type": "object",
      "description": "Ответ на двухфакторную аутентификацию",
      "properties": {
        "accessToken": {
          "type": "string",
          "description": "JWT токен доступа"
        },
        "refreshToken": {
          "type": "string",
          "description": "Токен для обновления доступа"
        },
        "expiresIn": {
          "type": "integer",
          "description": "Время жизни токена в секундах",
          "minimum": 1
        },
        "tokenType": {
          "type": "string",
          "description": "Тип токена"
        }
      },
      "required": ["accessToken", "refreshToken", "expiresIn"],
      "additionalProperties": false
    },
    
    "Error": {
      "type": "object",
      "description": "Стандартный ответ с ошибкой",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Код ошибки"
            },
            "message": {
              "type": "string",
              "description": "Сообщение об ошибке"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Время возникновения ошибки"
            }
          },
          "required": ["code", "message", "timestamp"],
          "additionalProperties": false
        }
      },
      "required": ["error"],
      "additionalProperties": false
    }
  }
}