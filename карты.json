{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/GimatutdinovaL/srs/refs/heads/main/карты.json",
  "title": "OpenAPI-спецификация Сервиса управления банковскими картами",
  "description": "Методы для управления банковскими картами. Все схемы запросов и ответов соответствуют JSON Schema не ниже Draft 4",
  "type": "object",
  "properties": {
    "Link": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "href": {
          "type": "string",
          "description": "URL ссылки"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE"],
          "description": "HTTP метод"
        }
      }
    },
    "CardProduct": {
      "type": "object",
      "additionalProperties": false,
      "description": "Вид банковской карты",
      "required": ["id", "productType"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор вида карты"
        },
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        }
      }
    },
    "CardProductsRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Список карт",
      "required": ["products", "_links"],
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "$ref": "#/properties/CardProduct"
          }
        },
        "_links": {
          "type": "object",
          "additionalProperties": false,
          "required": ["self", "create_card"],
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "create_card": {
              "$ref": "#/properties/Link",
              "description": "Ссылка на создание заявки на новую карту"
            }
          }
        }
      }
    },
    "CardProductIDRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Конкретная информация о карте",
      "required": ["id", "name", "productType", "description", "annualFee", "cashback"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор вида карты"
        },
        "name": {
          "type": "string",
          "description": "Название карты"
        },
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты"
        },
        "description": {
          "type": "string",
          "description": "Описание карты"
        },
        "annualFee": {
          "type": "integer",
          "description": "Годовое обслуживание в руб."
        },
        "cashback": {
          "type": "string",
          "description": "Кешбэк"
        }
      }
    },
    "CardRQ": {
      "type": "object",
      "additionalProperties": false,
      "description": "Запрос на создание заявки на новую карту",
      "required": ["productType"],
      "properties": {
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        }
      }
    },
    "CardRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ответ на создание заявки на новую карту",
      "required": ["id", "date", "cardStatus", "productType"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор заявки на карту"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время создания"
        },
        "cardStatus": {
          "type": "string",
          "enum": ["NEW", "IN_PROGRESS", "COMPLETED", "CANCELLED"],
          "description": "Статус заказа"
        },
        "productType": {
          "type": "string",
          "enum": ["debit1", "debit2"],
          "description": "Тип карты с тарифом"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "cancel": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для отмены заявки"
            },
            "delivery_address": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для указания адреса доставки"
            }
          }
        }
      }
    },
    "DeliveryAddressCreateRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ответ на создание адреса доставки",
      "required": ["id", "_links"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор созданного адреса"
        },
        "_links": {
          "type": "object",
          "additionalProperties": false,
          "required": ["self"],
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "update": {
              "$ref": "#/properties/Link"
            }
          }
        }
      }
    },
    "DeliveryAddressCardRQ": {
      "type": "object",
      "additionalProperties": false,
      "description": "Запрос на создание адреса доставки",
      "required": ["cardId", "country", "city", "street", "houseNumber", "apartment"],
      "properties": {
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Комментарий для курьера (опционально)"
        }
      }
    },
    "DeliveryAddressCardRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ответ на получение адреса доставки",
      "required": ["id", "cardId", "createdAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор адреса"
        },
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "maxLength": 200,
          "description": "Комментарий для курьера"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время создания адреса"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link"
            },
            "update": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для обновления адреса доставки"
            }
          }
        }
      }
    },
    "DeliveryAddressUpdateRQ": {
      "type": "object",
      "additionalProperties": false,
      "description": "Запрос на обновление адреса доставки",
      "properties": {
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "maxLength": 200,
          "description": "Комментарий для курьера"
        }
      }
    },
    "DeliveryAddressUpdateRS": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ответ на обновление адреса доставки",
      "required": ["id", "cardId", "updatedAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Уникальный идентификатор адреса"
        },
        "cardId": {
          "type": "string",
          "format": "uuid",
          "description": "ID заявки на карту"
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Страна"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 50,
          "description": "Город"
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Улица"
        },
        "houseNumber": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Номер дома"
        },
        "apartment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10,
          "description": "Квартира/офис"
        },
        "comment": {
          "type": "string",
          "maxLength": 200,
          "description": "Комментарий для курьера"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Дата и время обновления адреса"
        },
        "_links": {
          "type": "object",
          "properties": {
            "self": {
              "$ref": "#/properties/Link",
              "description": "Ссылка для получения информации об обновленном адресе"
            }
          }
        }
      }
    },
    "Error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "timestamp"],
          "properties": {
            "code": {
              "type": "string",
              "description": "Код ошибки"
            },
            "message": {
              "type": "string",
              "description": "Сообщение об ошибке"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Время возникновения ошибки"
            }
          }
        }
      }
    }
  }
}